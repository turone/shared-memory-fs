{
  "extends": ["metarhia", "plugin:prettier/recommended"],
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "class-methods-use-this": "off"
  }
}
